class GradientReversalLayer(Function):
    @staticmethod
    def forward(ctx, x, alpha):
        ctx.alpha = alpha
        return x.view_as(x)

    @staticmethod
    def backward(ctx, grad_output):
        return grad_output.neg() * ctx.alpha, None


def grad_reverse(x, alpha=1.0):
    return GradientReversalLayer.apply(x, alpha)


class FiLM(nn.Module):
    def __init__(self, features, embedding_dim):
        super(FiLM, self).__init__()
        self.features = features
        self.fc = nn.Linear(embedding_dim, 2 * features)
        self.fc.weight.data.fill_(0)
        self.fc.bias.data.fill_(0)
        self.fc.bias.data[:features] = 1

    def forward(self, x, embedding):
        params = self.fc(embedding)
        gamma, beta = torch.split(params, self.features, dim=1)
        gamma = gamma.view(gamma.size(0), gamma.size(1), 1, 1, 1)
        beta = beta.view(beta.size(0), beta.size(1), 1, 1, 1)
        return x * gamma + beta


class DWIOnly_MaskedInstanceNorm3d(nn.Module):
    def __init__(self, num_channels=2, eps=1e-5):
        super().__init__()
        self.eps = eps

    def forward(self, x):
        dwi = x[:, 0:1, ...]
        t2 = x[:, 1:2, ...]
        with torch.no_grad():
            dwi_mask = (dwi > dwi.mean(dim=(2, 3, 4), keepdim=True)).float()
        mask_sum = dwi_mask.sum(dim=(2, 3, 4), keepdim=True) + self.eps
        dwi_mean = (dwi * dwi_mask).sum(dim=(2, 3, 4), keepdim=True) / mask_sum
        dwi_var = ((dwi - dwi_mean) ** 2 * dwi_mask).sum(dim=(2, 3, 4), keepdim=True) / mask_sum
        dwi_norm = (dwi - dwi_mean) / torch.sqrt(dwi_var + self.eps)
        t2_norm = t2
        return torch.cat([dwi_norm * dwi_mask, t2_norm], dim=1)


