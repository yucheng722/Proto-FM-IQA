# 2. Lightweight Attention Fusion
# ==========================================

class LightweightAttentionFusion(nn.Module):
    def __init__(self, channels=512):
        super().__init__()
        self.channel_attention = nn.Sequential(
            nn.AdaptiveAvgPool3d(1), nn.Flatten(),
            nn.Linear(channels * 2, channels // 8), nn.ReLU(),
            nn.Linear(channels // 8, channels * 2), nn.Sigmoid()
        )
        self.spatial_attention = nn.Sequential(
            nn.Conv3d(2, 1, kernel_size=3, padding=1, bias=False),
            nn.BatchNorm3d(1), nn.Sigmoid()
        )
        self.fusion_conv = nn.Sequential(
            nn.Conv3d(channels * 2, channels, kernel_size=1, bias=False),
            nn.BatchNorm3d(channels), nn.ReLU(inplace=True)
        )

    def forward(self, dwi_feat, t2_feat):
        combined = torch.cat([dwi_feat, t2_feat], dim=1)
        channel_weights = self.channel_attention(combined)
        channel_weights = channel_weights.view(-1, 2, 512)
        dwi_weight = channel_weights[:, 0, :].view(-1, 512, 1, 1, 1)
        t2_weight = channel_weights[:, 1, :].view(-1, 512, 1, 1, 1)
        dwi_weighted = dwi_feat * dwi_weight
        t2_weighted = t2_feat * t2_weight
        dwi_spatial = torch.mean(dwi_weighted, dim=1, keepdim=True)
        t2_spatial = torch.mean(t2_weighted, dim=1, keepdim=True)
        spatial_input = torch.cat([dwi_spatial, t2_spatial], dim=1)
        spatial_weights = self.spatial_attention(spatial_input)
        weighted_sum = (dwi_weighted + t2_weighted) * spatial_weights
        fused = self.fusion_conv(torch.cat([dwi_feat, t2_feat], dim=1))
        fused = fused + weighted_sum
        return fused


