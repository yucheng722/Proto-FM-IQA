class DualChannelDataset(Dataset):
    def __init__(self, dwi_paths, t2_paths, labels, b_map=None, is_train=False):
        self.dwi_paths = dwi_paths
        self.t2_paths = t2_paths
        self.labels = labels
        self.b_map = b_map
        self.is_train = is_train  

        assert len(dwi_paths) == len(t2_paths)
        assert len(dwi_paths) == len(labels)

    def __len__(self):
        return len(self.dwi_paths)

    def __getitem__(self, idx):
        dwi = preprocess_image_sitk(self.dwi_paths[idx])  
        t2  = preprocess_image_sitk(self.t2_paths[idx])   

        image = torch.cat([dwi, t2], dim=0)               
        image = image.float()
        
        # ==========================================
        if self.is_train:
            image = apply_domain_randomization(image)

        label = torch.tensor(self.labels[idx], dtype=torch.long)

        phy_b = extract_b_value(self.dwi_paths[idx])
        if self.b_map is not None:
            b_val = torch.tensor(self.b_map.get(phy_b, 0), dtype=torch.long)
        else:
            b_val = torch.tensor(phy_b, dtype=torch.long)

        return image, label, b_val

def random_noise(image, prob=0.5, mean=0.0, std_range=(0.01, 0.05)):
    if random.random() < prob:
        std = random.uniform(*std_range)
        noise = torch.randn_like(image) * std + mean
        image = image + noise
    return image


def random_blur_3d(image, prob=0.5, sigma_range=(0.5, 1.5)):
    if random.random() < prob:
        sigma = random.uniform(*sigma_range)
        for c in range(image.shape[0]):
            img_np = image[c].numpy()
            blurred_np = ndimage.gaussian_filter(img_np, sigma=sigma)
            image[c] = torch.from_numpy(blurred_np)
    return image


def random_contrast_brightness(image, prob=0.5, contrast_range=(0.7, 1.3), brightness_range=(-0.1, 0.1)):
    if random.random() < prob:
        contrast_factor = random.uniform(*contrast_range)
        brightness_factor = random.uniform(*brightness_range)
        # image = (image - mean) * contrast + mean + brightness
        mean_val = torch.mean(image)
        image = (image - mean_val) * contrast_factor + mean_val + brightness_factor
    return image


def apply_domain_randomization(image):
    # image shape: (Channels, Depth, Height, Width)
    image = random_contrast_brightness(image, prob=0.6)
    image = random_noise(image, prob=0.5)
    image = random_blur_3d(image, prob=0.4)
    return image

def get_dataloader_dual(src_base, tgt_base, batch_size, n_shot):
