    source_ds = DualChannelDataset(src_dwi, src_t2, src_lbl, b_map, is_train=True)
    source_sampler = build_balanced_sampler(src_lbl)
    source_loader = DataLoader(source_ds, batch_size=batch_size, sampler=source_sampler, num_workers=0)
    
    # ---------- 3. Helper to Merge Support and Query Dirs ----------
    def load_merged_data(base_sub):
        base = os.path.join(tgt_base, base_sub)
        dwi = get_file_list(base, "query_dwi") + get_file_list(base, "support_dwi")
        t2 = get_file_list(base, "query_t2") + get_file_list(base, "support_t2")
        return dwi, t2

    # ---------- 4. Load Cls_dis Domain Lists ----------
    dis_dwi0, dis_t20 = load_merged_data("Cls_pro_0")
    dis_dwi1, dis_t21 = load_merged_data("Cls_pro_1")
    dis_lists = (dis_dwi0, dis_t20, dis_dwi1, dis_t21)

    # ---------- 5. Load Cls_PIQUAL Domain Lists ----------
    piqual_dwi0, piqual_t20 = load_merged_data("Cls_PIQUAL_0")
    piqual_dwi1, piqual_t21 = load_merged_data("Cls_PIQUAL_1")
    piqual_lists = (piqual_dwi0, piqual_t20, piqual_dwi1, piqual_t21)

    # ---------- 6. Load PROMIS Domain Lists ----------
    p_dwi0, p_t20 = load_merged_data("Cls_0_PROMIS")
    p_dwi1, p_t21 = load_merged_data("Cls_1_PROMIS")
    promis_lists = (p_dwi0, p_t20, p_dwi1, p_t21)

    return source_loader, dis_lists, piqual_lists, promis_lists, b_map, unique_b


def get_random_loaders(dwi0, t20, dwi1, t21, b_map, n_shot):
    import os
    
    idx0 = list(range(len(dwi0)))
    random.shuffle(idx0)
    sup0_idx, qry0_idx = idx0[:n_shot], idx0[n_shot:]

    idx1 = list(range(len(dwi1)))
    random.shuffle(idx1)
    sup1_idx, qry1_idx = idx1[:n_shot], idx1[n_shot:]

    sup_dwi = [dwi0[i] for i in sup0_idx] + [dwi1[i] for i in sup1_idx]
    sup_t2 = [t20[i] for i in sup0_idx] + [t21[i] for i in sup1_idx]
    sup_lbl = [0] * n_shot + [1] * n_shot

    support_ids = [os.path.basename(p) for p in sup_dwi]

    qry_dwi = [dwi0[i] for i in qry0_idx] + [dwi1[i] for i in qry1_idx]
    qry_t2 = [t20[i] for i in qry0_idx] + [t21[i] for i in qry1_idx]
    qry_lbl = [0] * len(qry0_idx) + [1] * len(qry1_idx)

    support_ds = DualChannelDataset(sup_dwi, sup_t2, sup_lbl, b_map)
    query_ds = DualChannelDataset(qry_dwi, qry_t2, qry_lbl, b_map)

    support_loader = DataLoader(support_ds, batch_size=1, shuffle=False)
    query_loader = DataLoader(query_ds, batch_size=1, shuffle=False)

    return support_loader, query_loader, support_ids


