class DualPathConditionedResNet(nn.Module):
    def __init__(self, original_backbone, b_vocab_size, embedding_dim=16,
                 pretrained_path=None, mode='dual'):
        super().__init__()
        self.mode = mode

        def _create_backbone(original_backbone, pretrained_path, channel=1):
            backbone = ResNet(BasicBlock, [2, 2, 2, 2],
                              sample_input_D=32, sample_input_H=192, sample_input_W=192,
                              num_seg_classes=512)
            if pretrained_path and os.path.exists(pretrained_path):
                state = torch.load(pretrained_path, map_location='cpu')
                new_state = {k.replace("module.", ""): v for k, v in state.items()}
                own_state = backbone.state_dict()
                for name, param in new_state.items():
                    if name in own_state:
                        if name == 'conv1.weight':
                            if param.size(1) == 1:
                                own_state[name][:, :channel, ...] = param[:, :, ...]
                            else:
                                own_state[name][:, :channel, ...] = param[:, :1, ...]
                        else:
                            own_state[name].copy_(param)
            old_conv = backbone.conv1
            backbone.conv1 = nn.Conv3d(channel, old_conv.out_channels,
                                       kernel_size=old_conv.kernel_size, stride=old_conv.stride,
                                       padding=old_conv.padding, bias=old_conv.bias)
            if pretrained_path and os.path.exists(pretrained_path):
                with torch.no_grad():
                    backbone.conv1.weight[:, :channel, ...] = old_conv.weight[:, :channel, ...]
                    if backbone.conv1.bias is not None:
                        backbone.conv1.bias.data.copy_(old_conv.bias.data)
            return backbone

        if self.mode == 'dual':
            self.dwi_backbone = _create_backbone(original_backbone, pretrained_path, channel=1)
            self.t2_backbone = _create_backbone(original_backbone, pretrained_path, channel=1)
            self.b_embedding = nn.Embedding(b_vocab_size, embedding_dim)
            self.film1 = FiLM(64, embedding_dim)
            self.film2 = FiLM(128, embedding_dim)
            self.film3 = FiLM(256, embedding_dim)
            self.film4 = FiLM(512, embedding_dim)
            self.dwi_only_norm = DWIOnly_MaskedInstanceNorm3d(num_channels=2)
            self.fusion = LightweightAttentionFusion(channels=512)

        elif self.mode == 'dwi_only_conditioned':
            self.dwi_backbone = _create_backbone(original_backbone, pretrained_path, channel=1)
            self.b_embedding = nn.Embedding(b_vocab_size, embedding_dim)
            self.film1 = FiLM(64, embedding_dim)
            self.film2 = FiLM(128, embedding_dim)
            self.film3 = FiLM(256, embedding_dim)
            self.film4 = FiLM(512, embedding_dim)
            self.dwi_only_norm = DWIOnly_MaskedInstanceNorm3d(num_channels=2)

        elif self.mode == 'dwi_only_plain':
            self.dwi_backbone = _create_backbone(original_backbone, pretrained_path, channel=1)

    def forward(self, x, b_idx):
        if self.mode == 'dual':
            x_norm = self.dwi_only_norm(x)
            dwi = x_norm[:, 0:1, ...]
            t2 = x_norm[:, 1:2, ...]
            b_emb = self.b_embedding(b_idx)
            dwi_feat = self.dwi_backbone.conv1(dwi)
            dwi_feat = self.dwi_backbone.bn1(dwi_feat)
            dwi_feat = self.dwi_backbone.relu(dwi_feat)
            dwi_feat = self.dwi_backbone.maxpool(dwi_feat)
            dwi_feat = self.dwi_backbone.layer1(dwi_feat)
            dwi_feat = self.film1(dwi_feat, b_emb)
            dwi_feat = self.dwi_backbone.layer2(dwi_feat)
            dwi_feat = self.film2(dwi_feat, b_emb)
            dwi_feat = self.dwi_backbone.layer3(dwi_feat)
            dwi_feat = self.film3(dwi_feat, b_emb)
            dwi_feat = self.dwi_backbone.layer4(dwi_feat)
            dwi_feat = self.film4(dwi_feat, b_emb)

            t2_feat = self.t2_backbone.conv1(t2)
            t2_feat = self.t2_backbone.bn1(t2_feat)
            t2_feat = self.t2_backbone.relu(t2_feat)
            t2_feat = self.t2_backbone.maxpool(t2_feat)
            t2_feat = self.t2_backbone.layer1(t2_feat)
            t2_feat = self.t2_backbone.layer2(t2_feat)
            t2_feat = self.t2_backbone.layer3(t2_feat)
            t2_feat = self.t2_backbone.layer4(t2_feat)

            fused = self.fusion(dwi_feat, t2_feat)
            return fused, b_emb

        elif self.mode == 'dwi_only_conditioned':
            dwi = x[:, 0:1, ...]
            x_norm = self.dwi_only_norm(x)
            dwi_norm = x_norm[:, 0:1, ...]
            b_emb = self.b_embedding(b_idx)
            dwi_feat = self.dwi_backbone.conv1(dwi_norm)
            dwi_feat = self.dwi_backbone.bn1(dwi_feat)
            dwi_feat = self.dwi_backbone.relu(dwi_feat)
            dwi_feat = self.dwi_backbone.maxpool(dwi_feat)
            dwi_feat = self.dwi_backbone.layer1(dwi_feat)
            dwi_feat = self.film1(dwi_feat, b_emb)
            dwi_feat = self.dwi_backbone.layer2(dwi_feat)
            dwi_feat = self.film2(dwi_feat, b_emb)
            dwi_feat = self.dwi_backbone.layer3(dwi_feat)
            dwi_feat = self.film3(dwi_feat, b_emb)
            dwi_feat = self.dwi_backbone.layer4(dwi_feat)
            dwi_feat = self.film4(dwi_feat, b_emb)
            return dwi_feat, b_emb

        elif self.mode == 'dwi_only_plain':
            dwi = x[:, 0:1, ...]
            dwi_feat = self.dwi_backbone.conv1(dwi)
            dwi_feat = self.dwi_backbone.bn1(dwi_feat)
            dwi_feat = self.dwi_backbone.relu(dwi_feat)
            dwi_feat = self.dwi_backbone.maxpool(dwi_feat)
            dwi_feat = self.dwi_backbone.layer1(dwi_feat)
            dwi_feat = self.dwi_backbone.layer2(dwi_feat)
            dwi_feat = self.dwi_backbone.layer3(dwi_feat)
            dwi_feat = self.dwi_backbone.layer4(dwi_feat)
            return dwi_feat, None


class Model(nn.Module):
    def __init__(self, backbone, num_classes=2, num_prototypes=5, b_vocab_size=10,
                 pretrained_path=None, mode='dual'):
        super(Model, self).__init__()
        self.mode = mode

        self.encoder = DualPathConditionedResNet(backbone, b_vocab_size,
                                                 pretrained_path=pretrained_path,
                                                 mode=mode)
        self.avgpool = nn.AdaptiveAvgPool3d((1, 1, 1))
        self.projector = nn.Sequential(
            nn.Flatten(),
            nn.Linear(512, 256),
            nn.BatchNorm1d(256),
            nn.ReLU(),
            nn.Linear(256, 128)
        )
        self.prototypes = nn.Parameter(torch.randn(num_classes, num_prototypes, 128))

        if mode in ['dual', 'dwi_only_conditioned']:
            self.discriminator = nn.Sequential(
                nn.Flatten(),
                nn.Linear(512, 256),
                nn.ReLU(),
                nn.Linear(256, b_vocab_size)
            )
        else:
            self.discriminator = None

    def forward_encoder(self, x, b_idx):
        feat_map, b_emb = self.encoder(x, b_idx)
        feat = self.avgpool(feat_map)
        emb = self.projector(feat)
        return F.normalize(emb, dim=1)

    def forward_with_prototypes(self, x, b_idx, prototypes, alpha_grl=1.0):
        feat_map, b_emb = self.encoder(x, b_idx)
        feat_vec = self.avgpool(feat_map)
        emb = self.projector(feat_vec)
        emb_norm = F.normalize(emb, p=2, dim=1)

        if prototypes is not None:
            proto_norm = F.normalize(prototypes, p=2, dim=1)
            logits = torch.matmul(emb_norm, proto_norm.T)
        else:
            proto_norm = F.normalize(self.prototypes, p=2, dim=2)
            sim_matrix = torch.einsum('bd,ckd->bck', emb_norm, proto_norm)
            logits, _ = torch.max(sim_matrix, dim=2)

        b_pred = None
        if self.discriminator is not None and b_emb is not None:
            feat_rev = grad_reverse(feat_vec, alpha_grl)
            b_pred = self.discriminator(feat_rev)

        return logits, emb, b_pred

    def forward(self, x, b_idx, alpha_grl=1.0):
        return self.forward_with_prototypes(x, b_idx, None, alpha_grl)


