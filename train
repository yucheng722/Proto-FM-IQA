def run_few_shot_test(model, support_loader, query_loader, device, k_shot=5):
    model.eval()
    support_embs = []
    support_lbls = []
    all_scores = []
    all_labels = []
    with torch.no_grad():
        for imgs, lbls, b_idxs in support_loader:
            imgs, b_idxs = imgs.to(device), b_idxs.to(device)
            feat_map, _ = model.encoder(imgs, b_idxs)
            feat_vec = model.avgpool(feat_map)
            emb = model.projector(feat_vec)
            support_embs.append(emb)
            support_lbls.append(lbls)

    support_embs = torch.cat(support_embs, dim=0)
    support_lbls = torch.cat(support_lbls, dim=0)
    unique_classes = torch.unique(support_lbls)
    adapted_protos = {}
    for c in unique_classes:
        c = c.item()
        mask = (support_lbls == c)
        proto = F.normalize(support_embs[mask].mean(dim=0), p=2, dim=0)
        adapted_protos[c] = proto

    correct = 0
    total = 0
    TP, TN, FP, FN = 0, 0, 0, 0
    with torch.no_grad():
        for imgs, lbls, b_idxs in query_loader:
            imgs, lbls, b_idxs = imgs.to(device), lbls.to(device), b_idxs.to(device)
            feat_map, _ = model.encoder(imgs, b_idxs)
            emb = model.projector(model.avgpool(feat_map))
            emb_norm = F.normalize(emb, p=2, dim=1)
            scores = []
            for c in [0, 1]:
                if c in adapted_protos:
                    proto = adapted_protos[c].to(device)
                    proto_norm = F.normalize(proto.unsqueeze(0), p=2, dim=1)
                    sim = torch.matmul(emb_norm, proto_norm.T)
                    scores.append(sim)
                else:
                    scores.append(torch.full((emb.size(0), 1), -1e9).to(device))
            scores = torch.cat(scores, dim=1)
            preds = torch.argmax(scores, dim=1)
            prob_pos = F.softmax(scores, dim=1)[:, 1]
            all_scores.append(prob_pos.detach().cpu())
            all_labels.append(lbls.detach().cpu())
            correct += (preds == lbls).sum().item()
            total += lbls.size(0)
            tp = ((preds == 1) & (lbls == 1)).sum().item()
            tn = ((preds == 0) & (lbls == 0)).sum().item()
            fp = ((preds == 1) & (lbls == 0)).sum().item()
            fn = ((preds == 0) & (lbls == 1)).sum().item()
            TP += tp;
            TN += tn;
            FP += fp;
            FN += fn

    acc = correct / max(total, 1)
    sens = TP / (TP + FN + 1e-8)
    spec = TN / (TN + FP + 1e-8)
    all_scores = torch.cat(all_scores).numpy()
    all_labels = torch.cat(all_labels).numpy()
    auc = roc_auc_score(all_labels, all_scores)
    sen_at_80spec, spe_at_80sens = compute_conditional_metrics(all_labels, all_scores)
    return acc, sens, spec, auc, sen_at_80spec, spe_at_80sens


def extract_and_cache_features(model, data_lists, b_map, device):
    dwi0, t20, dwi1, t21 = data_lists

    all_dwi = dwi0 + dwi1
    all_t2 = t20 + t21
    all_lbl = [0] * len(dwi0) + [1] * len(dwi1)

    full_ds = DualChannelDataset(all_dwi, all_t2, all_lbl, b_map)
    full_loader = DataLoader(full_ds, batch_size=1, shuffle=False, num_workers=0)

    cached_features = {}
    model.eval()

    with torch.no_grad():
        for i, (imgs, lbls, b_idxs) in enumerate(full_loader):
            imgs, b_idxs = imgs.to(device), b_idxs.to(device)
            feat_map, _ = model.encoder(imgs, b_idxs)
            feat_vec = model.avgpool(feat_map)
            emb = model.projector(feat_vec)

            img_id = os.path.basename(all_dwi[i])

            cached_features[img_id] = {
                "emb": emb.cpu(),  
                "label": lbls.item()
            }

    return cached_features


def evaluate_50_runs(model, data_lists, b_map, n_shot, device):
    import os
    import random

    cached_features = extract_and_cache_features(model, data_lists, b_map, device)

    dwi0, t20, dwi1, t21 = data_lists

    metrics_all = {"acc": [], "sens": [], "spec": [], "auc": [], "sen@80spec": [], "spe@80sens": []}
    support_ids_all = []

    ids_0 = [os.path.basename(p) for p in dwi0]
    ids_1 = [os.path.basename(p) for p in dwi1]

    for _ in range(50):
        random.shuffle(ids_0)
        random.shuffle(ids_1)

        sup0_ids, qry0_ids = ids_0[:n_shot], ids_0[n_shot:]
        sup1_ids, qry1_ids = ids_1[:n_shot], ids_1[n_shot:]

        sup_ids = sup0_ids + sup1_ids
        qry_ids = qry0_ids + qry1_ids

        support_ids_all.append(sup_ids)

        sup_embs_0 = torch.cat([cached_features[i]["emb"] for i in sup0_ids], dim=0).to(device)
        sup_embs_1 = torch.cat([cached_features[i]["emb"] for i in sup1_ids], dim=0).to(device)

        proto_0 = F.normalize(sup_embs_0.mean(dim=0, keepdim=True), p=2, dim=1)
        proto_1 = F.normalize(sup_embs_1.mean(dim=0, keepdim=True), p=2, dim=1)
        prototypes = torch.cat([proto_0, proto_1], dim=0)  

        qry_embs = torch.cat([cached_features[i]["emb"] for i in qry_ids], dim=0).to(device)
        qry_lbls = torch.tensor([cached_features[i]["label"] for i in qry_ids]).to(device)

        qry_embs_norm = F.normalize(qry_embs, p=2, dim=1)

        sim_scores = torch.matmul(qry_embs_norm, prototypes.T)  

        preds = torch.argmax(sim_scores, dim=1)
        prob_pos = F.softmax(sim_scores, dim=1)[:, 1]

        correct = (preds == qry_lbls).sum().item()
        total = len(qry_lbls)

        tp = ((preds == 1) & (qry_lbls == 1)).sum().item()
        tn = ((preds == 0) & (qry_lbls == 0)).sum().item()
        fp = ((preds == 1) & (qry_lbls == 0)).sum().item()
        fn = ((preds == 0) & (qry_lbls == 1)).sum().item()

        acc = correct / max(total, 1)
        sens = tp / (tp + fn + 1e-8)
        spec = tn / (tn + fp + 1e-8)

        prob_pos_np = prob_pos.detach().cpu().numpy()
        lbls_np = qry_lbls.cpu().numpy()

        auc = roc_auc_score(lbls_np, prob_pos_np)
        sen_at_80spec, spe_at_80sens = compute_conditional_metrics(lbls_np, prob_pos_np)

        metrics_all["acc"].append(acc)
        metrics_all["sens"].append(sens)
        metrics_all["spec"].append(spec)
        metrics_all["auc"].append(auc)
        metrics_all["sen@80spec"].append(sen_at_80spec)
        metrics_all["spe@80sens"].append(spe_at_80sens)

    stats = {}
    for k, v_list in metrics_all.items():
        v_arr = np.array(v_list)
        max_idx = int(np.argmax(v_arr))
        min_idx = int(np.argmin(v_arr))

        stats[k] = {
            "mean": float(np.mean(v_arr)),
            "std": float(np.std(v_arr)),
            "max": float(v_arr[max_idx]),
            "min": float(v_arr[min_idx]),
            "max_support_ids": support_ids_all[max_idx],
            "min_support_ids": support_ids_all[min_idx]
        }
    return stats

def train_epoch(epoch, model, train_loader, optimizer, criterion_ce, criterion_adv,
                device, alpha_grl, n_way):
    model.train()
    total_loss = 0;
    total_cls_loss = 0;
    total_adv_loss = 0

    for episode in tqdm(train_loader, desc=f"Ep {epoch}"):
        support_x, support_y, support_b, query_x, query_y, query_b = episode
        support_x = support_x.squeeze(0).to(device)
        support_y = support_y.squeeze(0).to(device)
        support_b = support_b.squeeze(0).to(device)
        query_x = query_x.squeeze(0).to(device)
        query_y = query_y.squeeze(0).to(device)
        query_b = query_b.squeeze(0).to(device)

        support_emb = model.forward_encoder(support_x, support_b)
        prototypes = []
        for c in range(n_way):
            mask = (support_y == c)
            if mask.sum() > 0:
                class_proto = F.normalize(support_emb[mask].mean(dim=0, keepdim=True), p=2, dim=1)
            else:
                class_proto = torch.zeros(1, support_emb.size(1)).to(device)
            prototypes.append(class_proto)
        prototypes = torch.cat(prototypes, dim=0)

        query_logits, _, query_b_pred = model.forward_with_prototypes(query_x, query_b, prototypes, alpha_grl)
        loss_cls = criterion_ce(query_logits, query_y)

        loss_adv = 0
        if model.discriminator is not None:
            _, _, support_b_pred = model.forward_with_prototypes(support_x, support_b, None, alpha_grl)
            loss_adv = criterion_adv(support_b_pred, support_b)

        loss = loss_cls + 0.5 * loss_adv
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

        total_loss += loss.item()
        total_cls_loss += loss_cls.item()
        total_adv_loss += loss_adv.item()

    avg_loss = total_loss / len(train_loader)
    avg_cls_loss = total_cls_loss / len(train_loader)
    avg_adv_loss = total_adv_loss / len(train_loader)
    return avg_loss, avg_cls_loss, avg_adv_loss


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument('--src_base', default="/path/to/data")
    parser.add_argument('--tgt_base', default="/path/to/data")
    parser.add_argument("--n_shot", type=int, default=5)
    parser.add_argument('--n_way', type=int, default=2)
    parser.add_argument('--n_query', type=int, default=5)
    parser.add_argument('--output_dir', default="./results_dual_pro_aug")
    parser.add_argument('--epochs', type=int, default=10)
    parser.add_argument('--batch_size', type=int, default=10)
    parser.add_argument('--lr', type=float, default=1e-4)
    parser.add_argument('--pretrained_path',
                        default='/path/to/pretrained/resnet_18_23dataset.pth')
    parser.add_argument('--mode', type=str, default='dual',
                        choices=['dual', 'dwi_only_conditioned', 'dwi_only_plain'],
                        help='Model mode: dual (DWI+T2), dwi_only_conditioned (DWI with FiLM), dwi_only_plain (DWI only)')

    args = parser.parse_args()
    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')

    os.makedirs(args.output_dir, exist_ok=True)

    (train_loader, dis_lists, piqual_lists, promis_lists, b_map, unique_b) = get_dataloader_dual(
        args.src_base, args.tgt_base, args.batch_size, args.n_shot
    )

    base_train_dataset = train_loader.dataset

    episode_dataset = EpisodeDatasetWithB(
        base_dataset=base_train_dataset,
        n_way=args.n_way,
        k_shot=args.n_shot,
        n_query=args.n_query
    )

    train_episode_loader = DataLoader(
        episode_dataset,
        batch_size=1,
        shuffle=True,
        num_workers=0
    )

    raw_backbone = ResNet(BasicBlock, [2, 2, 2, 2],
                          sample_input_D=32, sample_input_H=192, sample_input_W=192,
                          num_seg_classes=512)

    model = Model(raw_backbone, b_vocab_size=len(unique_b),
                  pretrained_path=args.pretrained_path, mode=args.mode).to(device)

    optimizer = torch.optim.Adam(model.parameters(), lr=args.lr)
    criterion_ce = nn.CrossEntropyLoss(label_smoothing=0.3)
    criterion_adv = nn.CrossEntropyLoss()

    print(f"\n=== Phase 1: Episodic Meta-Training on Source Domain ===")
    print(f"Model Mode: {args.mode}")

    best_acc = 0
    for epoch in range(args.epochs):
        #p = float(epoch) / args.epochs
        #alpha = 2. / (1. + np.exp(-10 * p)) - 1

        p = float(epoch) / args.epochs
        warmup_epochs = args.epochs * 0.1
        if epoch < warmup_epochs:
            alpha = 1.0 * (float(epoch) / warmup_epochs)
        else:
            alpha = 1.0

        avg_loss, avg_cls_loss, avg_adv_loss = train_epoch(
            epoch, model, train_episode_loader, optimizer, criterion_ce,
            criterion_adv, device, alpha, args.n_way
        )

        print(f"Epoch {epoch + 1}/{args.epochs}: Loss={avg_loss:.4f} "
              f"(Cls={avg_cls_loss:.4f}, Adv={avg_adv_loss:.4f})")

        if (epoch + 1) % 1 == 0:
            model.eval()
            print(f"\n--- Epoch {epoch + 1} Evaluation (50 Random Runs per Dataset) ---")

            stats_p = evaluate_50_runs(model, promis_lists, b_map, args.n_shot, device)
            print(
                f"  [PROMIS]     Sen@80Spec: {stats_p['sen@80spec']['mean']:.4f} ± {stats_p['sen@80spec']['std']:.4f}")

            stats_dis = evaluate_50_runs(model, dis_lists, b_map, args.n_shot, device)
            print(
                f"  [Cls_dis]    Sen@80Spec: {stats_dis['sen@80spec']['mean']:.4f} ± {stats_dis['sen@80spec']['std']:.4f}")

            stats_piqual = evaluate_50_runs(model, piqual_lists, b_map, args.n_shot, device)
            print(
                f"  [Cls_PIQUAL] Sen@80Spec: {stats_piqual['sen@80spec']['mean']:.4f} ± {stats_piqual['sen@80spec']['std']:.4f}")

            current_mean_sen = stats_dis['sen@80spec']['mean']
            if current_mean_sen > best_acc:
                best_acc = current_mean_sen
                torch.save(model.state_dict(), os.path.join(args.output_dir, "best_model.pth"))
                print("  >> New Best Model Saved (based on Cls_dis)!")

            epoch_log = {
                "epoch": epoch + 1,
                "PROMIS_stats": stats_p,
                "Cls_dis_stats": stats_dis,
                "Cls_PIQUAL_stats": stats_piqual
            }
            log_path = os.path.join(args.output_dir, f"epoch_{epoch + 1}_stats.json")
            with open(log_path, 'w') as f:
                json.dump(epoch_log, f, indent=2)

            torch.save(model.state_dict(), os.path.join(args.output_dir, f"epoch_{epoch + 1}.pth"))

    # ==========================================
    # Phase 2: Final Evaluation 
    # ==========================================
    print("\n=== Phase 2: Final Evaluation on Target Domains (50 Runs) ===")

    best_model_path = os.path.join(args.output_dir, "best_model.pth")
    if os.path.exists(best_model_path):
        model.load_state_dict(torch.load(best_model_path))
        print(">>> Loaded best model for final evaluation.")

    print("\n--- Evaluating Cls_dis ---")
    stats_dis_final = evaluate_50_runs(model, dis_lists, b_map, args.n_shot, device)
    for k in stats_dis_final.keys():
        print(f"{k.capitalize():<12}: {stats_dis_final[k]['mean']:.4f} ± {stats_dis_final[k]['std']:.4f}")

    print("\n--- Evaluating Cls_PIQUAL ---")
    stats_piqual_final = evaluate_50_runs(model, piqual_lists, b_map, args.n_shot, device)
    for k in stats_piqual_final.keys():
        print(f"{k.capitalize():<12}: {stats_piqual_final[k]['mean']:.4f} ± {stats_piqual_final[k]['std']:.4f}")

    final_res = {
        "n_shot": args.n_shot,
        "epochs": args.epochs,
        "mode": args.mode,
        "runs": 50,
        "Cls_dis_final_stats": stats_dis_final,
        "Cls_PIQUAL_final_stats": stats_piqual_final
    }

    with open(os.path.join(args.output_dir, "final_results_50runs.json"), 'w') as f:
        json.dump(final_res, f, indent=2)

if __name__ == "__main__":
    main()
